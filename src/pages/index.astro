---
const basePath = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta content="width=device-width,initial-scale=1" name="viewport">
  <title>Next2D | Rendering Engine, Animation Tool, Underlying Framework.</title>
  <meta content="Next2D libraries and tool. Rendering Engine, Animation Tool, Underlying Framework. 2D entertainment development made easy! Fast! Comfortable!" name="description">
  <meta content="Next2D,Next2D Player,Animation Tool,Next2D Framework" name="keywords">

  <!-- Google / Search Engine Tags -->
  <meta itemprop="name" content="Next2D | Rendering Engine, Animation Tool, Underlying Framework.">
  <meta itemprop="description" content="Next2D Libraries and Tool. Rendering Engine, Animation Tool, Underlying Framework. 2D entertainment development made easy! Fast! Comfortable!">
  <meta itemprop="image" content="https://next2d.app/assets/img/ogp.png">

  <!-- Facebook Meta Tags -->
  <meta property="og:url" content="https://next2d.app">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Next2D | Rendering Engine, Animation Tool, Underlying Framework.">
  <meta property="og:description" content="Next2D libraries and tool. Rendering Engine, Animation Tool, Underlying Framework. 2D entertainment development made easy! Fast! Comfortable!">
  <meta property="og:image" content="https://next2d.app/assets/img/ogp.png">

  <!-- Twitter Meta Tags -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Next2D | Rendering Engine, Animation Tool, Underlying Framework.">
  <meta name="twitter:description" content="Next2D libraries and tool. Rendering Engine, Animation Tool, Underlying Framework. 2D entertainment development made easy! Fast! Comfortable!">
  <meta name="twitter:image" content="https://next2d.app/assets/img/ogp.png">

  <!-- Favicons -->
  <link href={`${basePath}assets/img/favicon.png`} rel="icon">
  <link href={`${basePath}assets/img/apple-touch-icon.png`} rel="apple-touch-icon">

  <!-- Vendor CSS -->
  <link href={`${basePath}assets/css/vendor/aos.css`} rel="stylesheet">
  <link href={`${basePath}assets/css/vendor/bootstrap.min.css`} rel="stylesheet">
  <link href={`${basePath}assets/css/vendor/bootstrap-icons.min.css`} rel="stylesheet">

  <!-- Main CSS -->
  <link href={`${basePath}assets/css/main.css`} rel="stylesheet">

  <!-- Global site tag (gtag.js) - Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-8GJWF4S3RH"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag("js", new Date());
    gtag("config", "G-8GJWF4S3RH");
  </script>
  <script data-ad-client="ca-pub-5673019255498912" async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js"></script>
  <script is:inline src="/assets/js/next2d.js"></script>
</head>
<body>
  <!-- ======= Hero Section ======= -->
  <section id="hero">
    <div class="hero-container">
      <h1>Next2D</h1>
      <h2>2D entertainment development made easy! Fast! Comfortable!</h2>
      <div id="next2d"></div>
      <script is:inline>
        next2d.load("assets/js/sample.json", { "tagId": "next2d", "bgColor": false });
      </script>
      <div class="hero-link">
        <a class="btn" href={`${basePath}en`}>English</a>
        <a class="btn" href={`${basePath}ja`}>日本語</a>
        <a class="btn" href={`${basePath}cn`}>简体中文</a>
      </div>
    </div>
  </section><!-- End Hero Section -->
</body>
</html>
