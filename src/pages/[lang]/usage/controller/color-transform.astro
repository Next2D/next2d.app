---
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import { getTranslations, supportedLanguages, isValidLanguage } from '../../../../i18n';

export function getStaticPaths() {
  return supportedLanguages.map((lang) => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;
if (!isValidLanguage(lang)) {
  return Astro.redirect('/ja/usage/controller/color-transform');
}

const t = await getTranslations(lang);
const basePath = import.meta.env.BASE_URL;

const breadcrumbs = [
  { label: t.navbar?.home || 'Home', href: `${basePath}${lang}/` },
  { label: t.main?.['usage-title'] || 'Usage', href: `${basePath}${lang}/usage/` },
  { label: 'Controller Area', href: `${basePath}${lang}/usage/controller/` },
  { label: t.toolmenu?.controller?.['color-transform'] || 'カラートランスフォーム' }
];
---

<DocsLayout
  title={t.toolusage?.controller?.['color-transform']?.title || 'カラートランスフォーム'}
  description={t.toolusage?.controller?.['color-transform']?.description || ''}
  lang={lang}
  t={t}
  breadcrumbs={breadcrumbs}
  menuType="usage"
>
  <div>
    <h3>{t.toolmenu?.controller?.['color-transform'] || 'カラートランスフォーム'}</h3>
    <p><iframe loading="lazy" width="560" height="350" src="https://www.youtube.com/embed/idqgkrERaE8" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></p>
    <p>{t.toolusage?.controller?.['color-transform']?.description || ''}</p>
  </div>
</DocsLayout>
