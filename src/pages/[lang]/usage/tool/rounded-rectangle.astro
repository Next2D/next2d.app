---
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import { getTranslations, supportedLanguages, isValidLanguage } from '../../../../i18n';

export function getStaticPaths() {
  return supportedLanguages.map((lang) => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;
if (!isValidLanguage(lang)) {
  return Astro.redirect('/ja/usage/tool/rounded-rectangle');
}

const t = await getTranslations(lang);
const basePath = import.meta.env.BASE_URL;

const breadcrumbs = [
  { label: t.navbar?.home || 'Home', href: `${basePath}${lang}/` },
  { label: t.main?.['usage-title'] || 'Usage', href: `${basePath}${lang}/usage/` },
  { label: 'Tool Area', href: `${basePath}${lang}/usage/tool/` },
  { label: t.toolmenu?.tool?.['rounded-rectangle'] || '角丸矩形ツール' }
];
---

<DocsLayout
  title={t.toolusage?.tool?.['rounded-rectangle']?.title || '角丸矩形ツール'}
  description={t.toolusage?.tool?.['rounded-rectangle']?.description || ''}
  lang={lang}
  t={t}
  breadcrumbs={breadcrumbs}
  menuType="usage"
>
  <div>
    <h3>{t.toolmenu?.tool?.['rounded-rectangle'] || '角丸矩形ツール'}</h3>
    <p><iframe loading="lazy" width="560" height="350" src="https://www.youtube.com/embed/mrAr_IVz8zY" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe></p>
    <h4>{t.toolusage?.tool?.['rounded-rectangle']?.description || ''}</h4>
    <p>{t.toolusage?.tool?.['rounded-rectangle']?.text1 || ''}</p>
  </div>
</DocsLayout>
