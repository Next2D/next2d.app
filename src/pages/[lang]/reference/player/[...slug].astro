---
import { getCollection } from 'astro:content';
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import { getTranslations, supportedLanguages, isValidLanguage } from '../../../../i18n';

export async function getStaticPaths() {
  const entries = await getCollection('player-specs');
  const paths: any[] = [];

  for (const lang of supportedLanguages) {
    // 言語ごとのエントリーをフィルタ
    const langEntries = entries.filter(entry => entry.id.startsWith(`${lang}/`));

    for (const entry of langEntries) {
      // ja/index.md → slug: undefined (index page)
      // ja/display-object.md → slug: display-object
      // ja/filters/index.md → slug: filters
      let slug = entry.id.replace(`${lang}/`, '').replace('.md', '');
      if (slug === 'index') {
        slug = undefined;
      } else if (slug.endsWith('/index')) {
        slug = slug.replace('/index', '');
      }

      paths.push({
        params: { lang, slug },
        props: { entry }
      });
    }
  }

  return paths;
}

const { lang, slug } = Astro.params;
const { entry } = Astro.props;

if (!isValidLanguage(lang)) {
  return Astro.redirect('/ja/reference/player/');
}

const t = await getTranslations(lang);
const basePath = import.meta.env.BASE_URL;

const { Content } = await entry.render();

// Markdownの最初の# からタイトルを抽出
const titleMatch = entry.body.match(/^#\s+(.+)$/m);
let title = titleMatch ? titleMatch[1] : 'Player Documentation';
// "Next2D "の重複を避ける（BaseLayoutで"Next2D | "が付くため）
title = title.replace(/^Next2D\s+/, '');

const breadcrumbs = [
  { label: t.navbar?.home || 'Home', href: `${basePath}${lang}/` },
  { label: 'Player', href: `${basePath}${lang}/reference/player/` },
  ...(slug ? [{ label: title }] : [])
];
---

<DocsLayout
  title={title}
  description={t.playerreference?.description || 'Next2D Player Documentation'}
  lang={lang}
  t={t}
  breadcrumbs={breadcrumbs}
  menuType="reference"
>
  <div class="docs-content">
    <Content />
  </div>
</DocsLayout>

<style>
  .docs-content :global(h1) {
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }

  .docs-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .docs-content :global(h3) {
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .docs-content :global(pre) {
    background-color: #2a2c30;
    color: #f8f9fa;
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .docs-content :global(code) {
    font-family: 'Monaco', 'Menlo', monospace;
    font-size: 0.9em;
  }

  .docs-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
  }

  .docs-content :global(th),
  .docs-content :global(td) {
    border: 1px solid #ddd;
    padding: 0.5rem;
    text-align: left;
  }

  .docs-content :global(th) {
    background-color: #f5f5f5;
  }
</style>
