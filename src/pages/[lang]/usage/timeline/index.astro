---
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import { getTranslations, supportedLanguages, isValidLanguage } from '../../../../i18n';

export function getStaticPaths() {
  return supportedLanguages.map((lang) => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;
if (!isValidLanguage(lang)) {
  return Astro.redirect('/ja/usage/timeline/');
}

const t = await getTranslations(lang);
const basePath = import.meta.env.BASE_URL;

const breadcrumbs = [
  { label: t.navbar?.home || 'Home', href: `${basePath}${lang}/` },
  { label: t.main?.['usage-title'] || 'Usage', href: `${basePath}${lang}/usage/` },
  { label: 'Timeline Area' }
];
---

<DocsLayout
  title={t.toolusage?.timeline?.title || 'Timeline Area'}
  description={t.toolusage?.timeline?.description || ''}
  lang={lang}
  t={t}
  breadcrumbs={breadcrumbs}
  menuType="usage"
>
  <div>
    <h3>Timeline Area</h3>
    <p>{t.toolusage?.timeline?.description || ''}</p>

    <h4>{t.toolmenu?.timeline?.['frame-keyframe'] || 'フレームとキーフレーム'}</h4>
    <p>{t.toolusage?.timeline?.['frame-keyframe']?.description || ''}</p>
    <p><a href={`${basePath}${lang}/usage/timeline/frame-keyframe`}>{t.main?.['read-more'] || 'Read more'}</a></p>

    <h4>{t.toolmenu?.timeline?.['normal-layer'] || '通常レイヤー'}</h4>
    <p>{t.toolusage?.timeline?.['normal-layer']?.description || ''}</p>
    <p><a href={`${basePath}${lang}/usage/timeline/normal-layer`}>{t.main?.['read-more'] || 'Read more'}</a></p>

    <h4>{t.toolmenu?.timeline?.['mask-layer'] || 'マスクレイヤー'}</h4>
    <p>{t.toolusage?.timeline?.['mask-layer']?.description || ''}</p>
    <p><a href={`${basePath}${lang}/usage/timeline/mask-layer`}>{t.main?.['read-more'] || 'Read more'}</a></p>

    <h4>{t.toolmenu?.timeline?.['motion-tweening'] || 'モーショントゥイーン'}</h4>
    <p>{t.toolusage?.timeline?.['motion-tweening']?.description || ''}</p>
    <p><a href={`${basePath}${lang}/usage/timeline/motion-tweening`}>{t.main?.['read-more'] || 'Read more'}</a></p>

    <h4>{t.toolmenu?.timeline?.['custom-tweening'] || 'カスタムモーショントゥイーン'}</h4>
    <p>{t.toolusage?.timeline?.['custom-tweening']?.description || ''}</p>
    <p><a href={`${basePath}${lang}/usage/timeline/custom-tweening`}>{t.main?.['read-more'] || 'Read more'}</a></p>

    <h4>{t.toolmenu?.timeline?.['onion-skin'] || 'オニオンスキン'}</h4>
    <p>{t.toolusage?.timeline?.['onion-skin']?.description || ''}</p>
    <p><a href={`${basePath}${lang}/usage/timeline/onion-skin`}>{t.main?.['read-more'] || 'Read more'}</a></p>

    <h4>{t.toolmenu?.timeline?.preview || 'プレビュー'}</h4>
    <p>{t.toolusage?.timeline?.preview?.description || ''}</p>
    <p><a href={`${basePath}${lang}/usage/timeline/preview`}>{t.main?.['read-more'] || 'Read more'}</a></p>

    <h4>JavaScript</h4>
    <p>{t.toolusage?.timeline?.javascript?.description || ''}</p>
    <p><a href={`${basePath}${lang}/usage/timeline/javascript`}>{t.main?.['read-more'] || 'Read more'}</a></p>
  </div>
</DocsLayout>
