---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/common/Header.astro';
import Footer from '../../../components/common/Footer.astro';
import Breadcrumbs from '../../../components/common/Breadcrumbs.astro';
import { getTranslations, supportedLanguages, isValidLanguage } from '../../../i18n';

export function getStaticPaths() {
  return supportedLanguages.map((lang) => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;
if (!isValidLanguage(lang)) {
  return Astro.redirect('/ja/privacy/');
}

const t = await getTranslations(lang);
const basePath = import.meta.env.BASE_URL;
const p = t.policy;

const breadcrumbs = [
  { label: t.navbar?.home || 'Home', href: `${basePath}${lang}/` },
  { label: p?.title || 'Privacy Policy' }
];
---

<BaseLayout
  title={p?.title || 'Privacy Policy'}
  description={p?.description || ''}
  lang={lang}
  breadcrumbs={breadcrumbs}
>
  <Header lang={lang} t={t} />

  <Breadcrumbs items={breadcrumbs} />

  <section id="privacy" class="padd-section">
    <div class="container">
      <div class="row">

        <!-- Last Updated -->
        <div class="col-md-8 offset-md-2">
          <h3>{p?.lastUpdated}</h3>
        </div>

        <!-- Overview -->
        <div class="col-md-8 offset-md-2">
          <h3>{p?.overview?.title}</h3>
          <p>{p?.overview?.text1}</p>
          <p>{p?.overview?.text2}</p>
        </div>

        <!-- Open Source License -->
        <div class="col-md-8 offset-md-2">
          <h3>{p?.openSource?.title}</h3>
          <p>{p?.openSource?.text1}</p>
          <p>{p?.openSource?.text2}</p>
        </div>

        <!-- No Personal Information Collection -->
        <div class="col-md-8 offset-md-2">
          <h3>{p?.noCollection?.title}</h3>
          <p>{p?.noCollection?.text1}</p>
          <ul>
            <li>{p?.noCollection?.list1}</li>
            <li>{p?.noCollection?.list2}</li>
            <li>{p?.noCollection?.list3}</li>
            <li>{p?.noCollection?.list4}</li>
          </ul>
          <p>{p?.noCollection?.text2}</p>
        </div>

        <!-- Third-Party Services -->
        <div class="col-md-8 offset-md-2">
          <h3>{p?.thirdParty?.title}</h3>
          <p>{p?.thirdParty?.text1}</p>
          <ul>
            <li><strong>{p?.thirdParty?.analytics?.name}</strong>: {p?.thirdParty?.analytics?.text}</li>
            <li><strong>{p?.thirdParty?.adsense?.name}</strong>: {p?.thirdParty?.adsense?.text}</li>
          </ul>
          <p>{p?.thirdParty?.text2}</p>
        </div>

        <!-- Cookies -->
        <div class="col-md-8 offset-md-2">
          <h3>{p?.cookies?.title}</h3>
          <p>{p?.cookies?.text1}</p>
          <p>{p?.cookies?.text2}</p>
        </div>

        <!-- Disclaimer -->
        <div class="col-md-8 offset-md-2">
          <h3>{p?.disclaimer?.title}</h3>
          <p>{p?.disclaimer?.text1}</p>
          <p>{p?.disclaimer?.text2}</p>
          <p><strong>{p?.disclaimer?.text3}</strong></p>
        </div>

        <!-- Changes to This Policy -->
        <div class="col-md-8 offset-md-2">
          <h3>{p?.changes?.title}</h3>
          <p>{p?.changes?.text1}</p>
        </div>

        <!-- Contact -->
        <div class="col-md-8 offset-md-2">
          <h3>{p?.contact?.title}</h3>
          <p>{p?.contact?.text1}</p>
          <p><a href={`mailto:${p?.contact?.email}`}>{p?.contact?.email}</a></p>
        </div>

      </div>
    </div>
  </section>

  <Footer lang={lang} t={t} />
</BaseLayout>
