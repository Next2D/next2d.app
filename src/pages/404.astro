---
const basePath = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta content="width=device-width,initial-scale=1" name="viewport">
  <title>404 Not Found | Next2D</title>
  <meta content="The page you are looking for could not be found." name="description">
  <meta name="robots" content="noindex">

  <!-- Favicons -->
  <link href={`${basePath}assets/img/favicon.png`} rel="icon">
  <link href={`${basePath}assets/img/apple-touch-icon.png`} rel="apple-touch-icon">

  <!-- Main CSS -->
  <link href={`${basePath}assets/css/main.css`} rel="stylesheet">
</head>
<body>
  <section id="hero">
    <div class="hero-container">
      <h1>404</h1>
      <h2>Page Not Found / ページが見つかりません / 页面未找到</h2>
      <div class="hero-link">
        <a class="btn" href={`${basePath}en/`}>English</a>
        <a class="btn" href={`${basePath}ja/`}>日本語</a>
        <a class="btn" href={`${basePath}cn/`}>简体中文</a>
      </div>
    </div>
  </section>
</body>
</html>
